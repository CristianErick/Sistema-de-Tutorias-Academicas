# Base de datos
DATABASE_URL=postgresql://usuario:contrasena@host:5432/tutorias_db

# Seguridad (generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=genera_una_clave_segura_aqui

# Puerto del servidor
PORT=3000

# Entorno
NODE_ENV=development

# CORS (orígenes permitidos, separados por coma)
CORS_ORIGIN=*

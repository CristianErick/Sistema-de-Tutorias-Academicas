# Base de datos (usar Neon, Supabase o Railway para produccion)
DATABASE_URL=postgresql://usuario:contrasena@host:5432/tutorias_db

# Seguridad (generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=genera_una_clave_segura_aqui

# Puerto del servidor
PORT=3000

# Entorno
NODE_ENV=development

# CORS (origenes permitidos, separados por coma)
CORS_ORIGIN=*

# --- Para Vercel ---
# Las variables de entorno se configuran desde el dashboard de Vercel:
# https://vercel.com/[tu-proyecto]/settings/environment-variables
# DATABASE_URL -> URL de PostgreSQL en la nube (Neon, Supabase, etc.)
# JWT_SECRET -> Clave secreta para JWT
# CORS_ORIGIN -> URL del dominio de Vercel (ej: https://tu-app.vercel.app)
